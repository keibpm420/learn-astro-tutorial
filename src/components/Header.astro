---
import Navigation from './Navigation.astro';
import Menu from './Menu.astro';
import ThemeIcon from './ThemeIcon.astro';
---

<header>
    <div class="logo"><a href="/">Logo</a></div>
    <div class="nav">
        <ThemeIcon />
        <Navigation />
        <Menu />
    </div>
</header>

<style>
    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #333;
        border-radius: 8px;
        padding: 8px 16px;
    }

    .logo a {
        text-decoration: none;
        font-weight: bold;
        font-size: 28px;
        color: white;
    }

    .nav {
        display: flex;
        gap: 12px;
        align-items: center;
    }
</style>
