---
const { platform, username } = Astro.props;
const date = new Date().getDate();
---

<a href={`https://www.${platform}.com/${username}`}>{platform}</a>
<span>{date}</span>

<style>
    a {
        color: inherit;
        padding: 0.5rem 1rem;
        color: white;
        background-color: #4c1d95;
        text-decoration: none;
    }
</style>
